# Copy to .env.seed and fill values.

# Network/program
ENDPOINT=https://api.explorer.provable.com/v1
NETWORK=testnet
PROGRAM_ID=zk_factor_12251.aleo

# Required actor keys
CREDITOR_PRIVATE_KEY=APrivateKey...
FACTOR1_PRIVATE_KEY=APrivateKey...
FACTOR2_PRIVATE_KEY=APrivateKey...

# Debtor can be provided as key or plain address.
DEBTOR_PRIVATE_KEY=APrivateKey...
# DEBTOR_ADDRESS=aleo1...

# Execution behavior
DRY_RUN=0
WAIT_CONFIRM=1

# 0 = execute_factoring (native credits), 1 = execute_factoring_token (USDC)
USE_TOKEN_PATH=0

# If native path is used, pre-create factor private credits from their own public balance.
FUND_NATIVE_FACTORS=1
FACTOR_NATIVE_FUND_MICRO=3000000

# Register rates and offer rate in BPS (e.g. 9000 = 90.00%)
REGISTER_MIN_RATE_BPS=8000
REGISTER_MAX_RATE_BPS=9500
OFFER_RATE_BPS=9000
