{
  "name": "zk-factor-root",
  "private": true,
  "scripts": {
    "guide:dev": "npm start --prefix guide",
    "guide:build": "npm run build --prefix guide",
    "client:dev": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client",
    "build": "npm run client:build && npm run guide:build && mkdir -p client/dist/docs && cp -r guide/build/* client/dist/docs/"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  }
}
