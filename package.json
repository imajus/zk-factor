{
  "name": "zk-factor",
  "private": true,
  "workspaces": [
    "client",
    "guide",
    "worker"
  ],
  "scripts": {
    "guide:dev": "npm run start -w guide",
    "guide:build": "npm run build -w guide",
    "client:dev": "npm run dev -w client",
    "client:build": "npm run build -w client",
    "worker:dev": "npm run dev -w worker",
    "worker:deploy": "npm run deploy -w worker",
    "build": "npm run client:build && npm run guide:build && mkdir -p client/dist/docs && cp -r guide/build/* client/dist/docs/"
  }
}